{
  "compilerOptions": {
    /* Language and Environment */
    "target": "es2022",
    /* Modules */
    "module": "commonjs",
    /* Emit */
    "outDir": "../js", // 编译输出目录
    "removeComments": true,
    "noEmitOnError": true,
    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    /* Type Checking */
    "strict": true,
    "skipLibCheck": true
  }
}
